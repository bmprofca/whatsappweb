# ===========================================
# LOCAL DEVELOPMENT (.env on your machine)
# ===========================================
NODE_ENV=development
PORT=5677
BASE_URL=http://localhost:5677

# ===========================================
# PRODUCTION (live server .env)
# ===========================================
# NODE_ENV=production
# PORT=3000
# BASE_URL=https://whatsappweb.onesaasbackend.com

# ===========================================
# DATABASE (same for local & production)
# ===========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=whatsapp_server

# ===========================================
# SECURITY
# ===========================================
API_KEY=your_api_key_here

# ===========================================
# OPTIONAL
# ===========================================
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_MS=2000
RECONNECT_DELAY_MS=5000
MAX_RECONNECT_ATTEMPTS=10
CORS_ORIGIN=*
